#!/usr/bin/env bash
# Ubuntu: install Multica backend + Next standalone + nginx (full stack) from this bundle.
# Run as root from the unpacked bundle directory (same level as linux/, install.sh).
#
#   sudo bash install.sh
#   sudo bash install.sh --replace-env
#   sudo bash install.sh --skip-nginx
#   sudo bash install.sh --skip-systemd
#
set -euo pipefail

DOMAIN='@@DOMAIN@@'
TLS_CRT='@@TLS_CRT@@'
TLS_KEY='@@TLS_KEY@@'
NEXT_PORT='@@NEXT_PORT@@'
NODE_BIN='@@NODE_BIN@@'

BACKEND_ROOT=/opt/multica
WEB_ROOT=/opt/multica-web
SERVICE_API=multica.service
SERVICE_WEB=multica-web.service

BUNDLE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPLACE_ENV=0
SKIP_NGINX=0
SKIP_SYSTEMD=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --replace-env) REPLACE_ENV=1; shift ;;
    --skip-nginx) SKIP_NGINX=1; shift ;;
    --skip-systemd) SKIP_SYSTEMD=1; shift ;;
    -h|--help) head -n 18 "$0"; exit 0 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

if [[ "$(id -u)" -ne 0 ]]; then
  echo "Run as root: sudo bash $0" >&2
  exit 1
fi

if [[ "$(uname -s)" != "Linux" ]]; then
  echo "This installer is for Linux. Current: $(uname -s)" >&2
  exit 1
fi

BACK="$BUNDLE_ROOT/linux"
if [[ ! -f "$BACK/bin/server" || ! -f "$BACK/bin/migrate" ]]; then
  echo "Missing $BACK/bin/server or migrate" >&2
  exit 1
fi
if [[ ! -f "$BACK/web-standalone/apps/web/server.js" ]]; then
  echo "Missing Next standalone at $BACK/web-standalone/apps/web/server.js" >&2
  exit 1
fi

if ! id multica &>/dev/null; then
  useradd --system --home-dir "$BACKEND_ROOT" --shell /usr/sbin/nologin multica
fi

mkdir -p "$BACKEND_ROOT/bin" "$BACKEND_ROOT/migrations" "$BACKEND_ROOT/data/uploads"
chown multica:multica "$BACKEND_ROOT"

install -o root -g root -m 0755 "$BACK/bin/server" "$BACKEND_ROOT/bin/server"
install -o root -g root -m 0755 "$BACK/bin/migrate" "$BACKEND_ROOT/bin/migrate"
rm -rf "${BACKEND_ROOT:?}/migrations"
cp -a "$BACK/migrations/." "$BACKEND_ROOT/migrations/"
chown -R root:multica "$BACKEND_ROOT/migrations"
chmod 0750 "$BACKEND_ROOT/migrations"
find "$BACKEND_ROOT/migrations" -type f -exec chmod 0640 {} \;
chown -R multica:multica "$BACKEND_ROOT/data"

if [[ -f "$BUNDLE_ROOT/.env" ]]; then
  if [[ ! -f "$BACKEND_ROOT/.env" ]] || [[ "$REPLACE_ENV" -eq 1 ]]; then
    install -o root -g multica -m 0640 "$BUNDLE_ROOT/.env" "$BACKEND_ROOT/.env"
    echo "==> Installed $BACKEND_ROOT/.env"
  else
    echo "==> Keeping $BACKEND_ROOT/.env (use --replace-env to overwrite)"
  fi
else
  echo "ERROR: bundle .env missing" >&2
  exit 1
fi

echo "==> Installing Next standalone → $WEB_ROOT"
rm -rf "${WEB_ROOT:?}"
mkdir -p "$WEB_ROOT"
cp -a "$BACK/web-standalone/." "$WEB_ROOT/"
chown -R multica:multica "$WEB_ROOT"

install -o root -g root -m 0644 "$BUNDLE_ROOT/$SERVICE_API" "/etc/systemd/system/$SERVICE_API"
install -o root -g root -m 0644 "$BUNDLE_ROOT/$SERVICE_WEB" "/etc/systemd/system/$SERVICE_WEB"
systemctl daemon-reload

if [[ "$SKIP_SYSTEMD" -eq 0 ]]; then
  systemctl enable "$SERVICE_API" "$SERVICE_WEB"
  echo "==> Enabled $SERVICE_API $SERVICE_WEB"
else
  echo "==> Skipped systemctl enable"
fi

if [[ "$SKIP_NGINX" -eq 0 ]]; then
  if ! command -v nginx &>/dev/null; then
    echo "nginx not installed; install nginx then copy $BUNDLE_ROOT/nginx-fullstack.conf" >&2
  else
    if [[ -d /etc/nginx/conf.d ]]; then
      install -o root -g root -m 0644 "$BUNDLE_ROOT/nginx-fullstack.conf" "/etc/nginx/conf.d/multica-fullstack.conf"
    elif [[ -d /etc/nginx/sites-available ]]; then
      install -o root -g root -m 0644 "$BUNDLE_ROOT/nginx-fullstack.conf" "/etc/nginx/sites-available/multica-fullstack.conf"
      ln -sf "/etc/nginx/sites-available/multica-fullstack.conf" "/etc/nginx/sites-enabled/multica-fullstack.conf"
    else
      echo "No nginx conf.d or sites-available" >&2
      exit 1
    fi
    mkdir -p /var/www/certbot
    if [[ -f "$TLS_CRT" && -f "$TLS_KEY" ]]; then
      nginx -t
      systemctl reload nginx || systemctl restart nginx
    else
      echo "==> Skipped nginx -t (add certs: $TLS_CRT $TLS_KEY)" >&2
    fi
  fi
else
  echo "==> Skipped nginx"
fi

echo ""
echo "Done."
echo "  sudo systemctl start $SERVICE_API"
echo "  sudo systemctl start $SERVICE_WEB"
echo "  Open: https://$DOMAIN"
echo "  Logs: journalctl -u $SERVICE_API -f   journalctl -u $SERVICE_WEB -f"
